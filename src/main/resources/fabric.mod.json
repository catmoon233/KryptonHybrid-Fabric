{
  "schemaVersion": 1,
  "id": "krypton_hybrid",
  "version": "${version}",
  "name": "Krypton Hybrid",
  "description": "A Fabric port of Krypton that accelerates the Minecraft networking stack with native compression/encryption and various packet optimizations.",
  "authors": [
    "xinian"
  ],
  "license": "GNU LGPL 3.0",
  "icon": "assets/krypton_hybrid/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.xinian.KryptonHybrid.kryptonhybrid"
    ]
  },
  "mixins": [
    "krypton_hybrid.mixins.json"
  ],
  "accessWidener": "krypton_hybrid.accesswidener",
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=21",
    "fabric-api": "*"
  }
}
